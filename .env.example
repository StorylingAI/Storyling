# ============================================
# STORYLING.AI ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in the actual values
# Get values from: Manus Management UI → Settings → Secrets
# ============================================

# ============================================
# DATABASE
# ============================================
DATABASE_URL=your_postgresql_connection_string_here

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
JWT_SECRET=your_jwt_secret_here
OAUTH_SERVER_URL=https://api.manus.im
OWNER_NAME=your_name_here
OWNER_OPEN_ID=your_open_id_here

# ============================================
# AI & CONTENT GENERATION
# ============================================
OPENAI_API_KEY=sk-your_openai_key_here
ELEVENLABS_API_KEY=your_elevenlabs_key_here
GOOGLE_CLOUD_API_KEY=your_google_cloud_key_here
GOOGLE_VEO_API_KEY=your_google_veo_key_here

# Video Generation APIs
SORA_API_KEY=your_sora_key_here
KLING_ACCESS_KEY=your_kling_access_key_here
KLING_SECRET_KEY=your_kling_secret_key_here
HIGGSFIELD_API_KEY_ID=your_higgsfield_key_id_here
HIGGSFIELD_API_KEY_SECRET=your_higgsfield_key_secret_here

# Manus Forge API (for AI features)
BUILT_IN_FORGE_API_KEY=your_forge_api_key_here
BUILT_IN_FORGE_API_URL=your_forge_api_url_here
VITE_FRONTEND_FORGE_API_KEY=your_frontend_forge_key_here
VITE_FRONTEND_FORGE_API_URL=your_frontend_forge_url_here

# ============================================
# STRIPE PAYMENT PROCESSING
# ============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Stripe Product/Price IDs
STRIPE_PRICE_PREMIUM_MONTHLY=price_your_monthly_price_id_here
STRIPE_PRICE_PREMIUM_ANNUAL=price_your_annual_price_id_here

# ============================================
# EMAIL (Resend)
# ============================================
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=Storyling AI <onboarding@resend.dev>

# ============================================
# APP URL (used for email verification links)
# ============================================
BASE_URL=http://localhost:3000

# ============================================
# FRONTEND CONFIGURATION
# ============================================
VITE_APP_URL=https://storyling.ai
VITE_APP_TITLE=Storyling.ai
VITE_APP_LOGO=/logo.png
VITE_APP_ID=your_app_id_here
VITE_OAUTH_PORTAL_URL=your_oauth_portal_url_here

# ============================================
# ANALYTICS
# ============================================
VITE_ANALYTICS_WEBSITE_ID=your_analytics_website_id_here
VITE_ANALYTICS_ENDPOINT=your_analytics_endpoint_here

# ============================================
# NOTES FOR DEPLOYMENT
# ============================================
# 
# LOCAL DEVELOPMENT:
# 1. Copy this file to .env in your project root
# 2. Fill in all values from Manus Management UI → Settings → Secrets
# 3. Never commit .env to Git (already in .gitignore)
# 
# PRODUCTION (Manus Hosting):
# - All secrets are automatically injected by Manus
# - No need to manually configure environment variables
# 
# EXTERNAL HOSTING (Railway, Render, Vercel, etc.):
# 1. Add each variable to your hosting platform's environment settings
# 2. Use production values (not test keys)
# 3. Ensure DATABASE_URL points to your production database
# 
# SECURITY REMINDERS:
# - Never share this file with actual values
# - Use different keys for development vs production
# - Rotate keys if accidentally exposed
# - Keep Stripe in test mode until ready for real payments
# 
# ============================================